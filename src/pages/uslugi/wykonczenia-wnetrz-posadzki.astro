---
import Layout from '../../layouts/Layout.astro';
import { withBase } from '../../lib/base.js';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import QuickQuoteCTA from '../../components/QuickQuoteCTA.astro';

import { Home, CheckCircle2, Phone, Utensils, Flame, Layers } from 'lucide-react';

const scope = [
  {
    title: 'Posadzki w Salonach i Kuchniach',
    desc: 'Duże powierzchnie podłogowe, często w formacie wielkoformatowym 120x60 cm / 120x120 cm z idealnie równą spoiną.'
  },
  {
    title: 'Fartuchy Kuchenne (Splashback)',
    desc: 'Montaż płytek lub płyt wielkoformatowych nad blatem z czystym docięciem przy gniazdkach i meblach oraz fugą plamoodporną.'
  },
  {
    title: 'Okładziny Kominkowe',
    desc: 'Ceramika i gres odporny na wysokie temperatury, dobierany pod konkretny model wkładu kominkowego.'
  },
  {
    title: 'Wykończenie Schodów i Podstopnic',
    desc: 'Stopnie i podstopnice z docięciem 45° lub wykończeniem antypoślizgowym w ciągach komunikacyjnych.'
  }
];
---

<Layout 
  title="Płytki w Salonie, Kuchni i na Schodach | TSS Płytki Kraków"
  description="Układanie płytek na podłogach, fartuchy kuchenne, okładziny kominków i schodów. Fuga cementowa lub epoksydowa. Kraków, Myślenice."
>
  <Navbar slot="navbar" />

  <section class="page-hero section-padding">
    <div class="container-custom">
      <div class="hero-badge">
        <Home size={16} class="text-gold" />
        <span>Posadzki & Wnętrza</span>
      </div>
      <h1>Wykończenia wnętrz i posadzki</h1>
      <p class="page-intro">
        Nie każda płytka kończy się w łazience. Podłogi w salonie, fartuch nad blatem kuchennym, okładzina kominka czy schody — każde z tych miejsc ma inne wymagania co do materiału i fugi.
      </p>
    </div>
  </section>

  <section class="section-padding bg-surface-wrap">
    <div class="container-custom">
      <div class="service-detail-grid">

        <div class="detail-main">
          <div class="glass-card detail-card">
            <h2>Płytki podłogowe i dekoracyjne we wnętrzu</h2>
            <p className="lead-p">
              Układamy gresy i płytki w każdym pomieszczeniu domu. Dobieramy odpowiednią fugę (cementową lub plamoodporną epoksydową) zależnie od przewidywanego obciążenia i wilgotności.
            </p>

            <div class="scope-grid">
              {scope.map(s => (
                <div class="scope-card">
                  <CheckCircle2 size={20} class="text-gold scope-icon" />
                  <div>
                    <strong>{s.title}</strong>
                    <p>{s.desc}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>

          <div class="glass-card detail-card margin-top">
            <h3>Fuga cementowa vs epoksydowa</h3>
            <p>
              <strong>Fuga cementowa</strong> sprawdza się świetnie w większości pomieszczeń mieszkalnych (salon, hol).
            </p>
            <p className="margin-top-sm">
              <strong>Fuga epoksydowa</strong> to idealny wybór do kuchni i korytarzy — jest w 100% plamoodporna, nie chłonie tłuszczu ani wina i ułatwia utrzymanie czystości na lata.
            </p>
          </div>
        </div>

        <div class="detail-sidebar">
          <div class="glass-card visual-card">
            <img src={withBase('/images/gallery-5.png')} alt="Posadzka z płytek gresowych w salonie" />
            <div class="card-caption">
              <strong>Posadzka w Salonie</strong>
              <small>Gres wielkoformatowy na podłogowym ogrzewaniu</small>
            </div>
          </div>

          <div class="glass-card sidebar-cta-box">
            <Utensils size={28} class="text-gold" />
            <h4>Fartuch kuchenny lub posadzka?</h4>
            <p>Pomożemy dobrać wzór układania (na wprost, cegiełka, jodełka) i wyliczyć odpad.</p>
            <a href="tel:603100978" class="btn btn-primary btn-sm w-full">
              <Phone size={16} />
              <span>Zadzwoń: 603 100 978</span>
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <QuickQuoteCTA 
    title="Remontujesz salon, kuchnię albo dokładasz kominek?" 
    subtitle="Zadzwoń do nas: 603 100 978 — wycenimy prace glazurnicze i doradzimy rodzaj fugi."
  />

  <Footer slot="footer" />
</Layout>

<style>
  .page-hero {
    padding-top: 4rem;
    padding-bottom: 3rem;
    text-align: center;
    background: radial-gradient(circle at 50% 20%, rgba(212, 163, 115, 0.08) 0%, transparent 60%);
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.35rem 0.85rem;
    background-color: var(--bg-card);
    border: 1px solid var(--border-gold);
    border-radius: var(--radius-full);
    font-size: 0.825rem;
    font-weight: 700;
    color: var(--accent-travertine);
    margin-bottom: 1rem;
  }

  .page-intro {
    font-size: 1.15rem;
    line-height: 1.65;
    max-width: 780px;
    margin: 1rem auto 0 auto;
    color: var(--text-muted);
  }

  .bg-surface-wrap {
    background-color: #0B0E14;
    border-top: 1px solid var(--border-stone);
    border-bottom: 1px solid var(--border-stone);
  }

  .service-detail-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 2.5rem;
  }

  .detail-card {
    padding: 2.25rem;
  }

  .lead-p {
    font-size: 1.05rem;
    line-height: 1.65;
    margin-bottom: 1.75rem;
  }

  .scope-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1.25rem;
  }

  .scope-card {
    display: flex;
    gap: 0.75rem;
    padding: 1.1rem;
    background-color: var(--bg-surface);
    border: 1px solid var(--border-stone);
    border-radius: var(--radius-md);
  }

  .scope-icon {
    flex-shrink: 0;
    margin-top: 2px;
  }

  .scope-card strong {
    display: block;
    color: var(--text-main);
    font-size: 0.95rem;
    margin-bottom: 0.2rem;
  }

  .scope-card p {
    font-size: 0.85rem;
    line-height: 1.5;
  }

  .margin-top { margin-top: 1.75rem; }
  .margin-top-sm { margin-top: 0.85rem; }

  .visual-card {
    padding: 0;
    overflow: hidden;
    margin-bottom: 1.5rem;
  }

  .visual-card img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
  }

  .card-caption {
    padding: 1rem 1.25rem;
    background-color: var(--bg-surface);
    border-top: 1px solid var(--border-stone);
  }

  .sidebar-cta-box {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }

  .w-full { width: 100%; }

  @media (max-width: 900px) {
    .service-detail-grid { grid-template-columns: 1fr; }
  }
</style>
