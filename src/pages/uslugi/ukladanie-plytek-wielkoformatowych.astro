---
import Layout from '../../layouts/Layout.astro';
import { withBase } from '../../lib/base.js';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import QuickQuoteCTA from '../../components/QuickQuoteCTA.astro';

import { Grid, CheckCircle2, Phone, Calculator, ArrowRight, ShieldCheck, Ruler } from 'lucide-react';

const reasons = [
  {
    title: 'Sztywność i Przygotowanie Podłoża',
    desc: 'Przed montażem sprawdzamy i w razie potrzeby wzmacniamy podkład wylewką samopoziomującą, żeby duża płyta nie pracowała pod obciążeniem.'
  },
  {
    title: 'Bezpieczny Transport i Podnoszenie',
    desc: 'Podnośniki i przyssawki próżniowe eliminują ryzyko pęknięcia przy przenoszeniu ciężkich płyt o wymiarach 120x120 cm i 120x240 cm.'
  },
  {
    title: 'Wąska, Równa Spoina',
    desc: 'Systemy poziomujące (kliny, klipsy) utrzymują stałą szerokość spoiny i jednakowy poziom bez uskoków na całej powierzchni.'
  },
  {
    title: 'Precyzyjne Cięcie Diamentowe',
    desc: 'Otwory pod gniazdka, baterie podtynkowe i odpływy wycinane chłodzonym wodą ostrzem diamentowym bez ryzyka odprysków.'
  }
];
---

<Layout 
  title="Układanie Płytek Wielkoformatowych | TSS Płytki Kraków"
  description="Montaż gresu i kwarcu wielkoformatowego 120×120 i 120×240 cm — podnośniki próżniowe, sztywne podłoże, wąska spoina. Kraków i Małopolska."
>
  <Navbar slot="navbar" />

  <section class="page-hero section-padding">
    <div class="container-custom">
      <div class="hero-badge">
        <Grid size={16} class="text-gold" />
        <span>Specjalizacja Wielki Format</span>
      </div>
      <h1>Układanie płytek wielkoformatowych</h1>
      <p class="page-intro">
        Płyty 120×120 cm i 120×240 cm zmieniają wnętrze — mniej fug, większe, spokojniejsze powierzchnie. Ale duży format wybacza mniej błędów niż standardowa płytka.
      </p>
    </div>
  </section>

  <section class="section-padding bg-surface-wrap">
    <div class="container-custom">
      <div class="service-detail-grid">

        <div class="detail-main">
          <div class="glass-card detail-card">
            <h2>Dlaczego wielki format wymaga innego podejścia?</h2>
            <p className="lead-p">
              Nierówne podłoże czy zły sposób podniesienia dużej płyty kończy się pęknięciem materiału. W TSS Płytki podchodzimy do płyt wielkoformatowych ze specjalistycznym sprzętem i 25-letnim doświadczeniem.
            </p>

            <ul class="reasons-list">
              {reasons.map((r) => (
                <li>
                  <CheckCircle2 size={22} class="text-gold reason-icon" />
                  <div>
                    <strong>{r.title}</strong>
                    <p>{r.desc}</p>
                  </div>
                </li>
              ))}
            </ul>
          </div>

          <div class="glass-card detail-card margin-top">
            <h3>Gdzie wielki format sprawdza się najlepiej?</h3>
            <p>
              Salony, open-space kuchnie połączone z strefą dzienną, luksusowe łazienki pod klucz oraz elewacje i tarasy w wersji mrozoodpornej gresowej.
            </p>
            <p className="margin-top-sm">
              <strong>Materiały, z którymi pracujemy:</strong> gres wielkoformatowy, spieki kwarcowe, imitacje kamienia naturalnego, marmuru i betonu architektonicznego.
            </p>
          </div>
        </div>

        <div class="detail-sidebar">
          <div class="glass-card visual-card">
            <img src={withBase('/images/gallery-2.webp')} alt="Układanie płytek wielkoformatowych 120x120 cm w Krakowie" />
            <div class="card-caption">
              <strong>Realizacja w Krakowie</strong>
              <small>Montaż płyt gresowych 120x120 cm na posadzce z ogrzewaniem</small>
            </div>
          </div>

          <div class="glass-card sidebar-cta-box">
            <h4>Wylicz zapotrzebowanie</h4>
            <p>Sprawdź metraż i orientacyjną liczbę kartonów w naszym kalkulatorze.</p>
            <a href={withBase('/kalkulator')} class="btn btn-secondary btn-sm w-full">
              <Calculator size={16} />
              <span>Otwórz kalkulator</span>
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <QuickQuoteCTA 
    title="Masz konkretny metraż i format w głowie?" 
    subtitle="Zadzwoń do Władysława Kuchni: 603 100 978 — omówimy wymogi podłoża i umówimy pomiar."
  />

  <Footer slot="footer" />
</Layout>

<style>
  .page-hero {
    padding-top: 4rem;
    padding-bottom: 3rem;
    text-align: center;
    background: radial-gradient(circle at 50% 20%, rgba(212, 163, 115, 0.08) 0%, transparent 60%);
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.35rem 0.85rem;
    background-color: var(--bg-card);
    border: 1px solid var(--border-gold);
    border-radius: var(--radius-full);
    font-size: 0.825rem;
    font-weight: 700;
    color: var(--accent-travertine);
    margin-bottom: 1rem;
  }

  .page-intro {
    font-size: 1.15rem;
    line-height: 1.65;
    max-width: 780px;
    margin: 1rem auto 0 auto;
    color: var(--text-muted);
  }

  .bg-surface-wrap {
    background-color: #0B0E14;
    border-top: 1px solid var(--border-stone);
    border-bottom: 1px solid var(--border-stone);
  }

  .service-detail-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 2.5rem;
  }

  .detail-card {
    padding: 2.25rem;
  }

  .detail-card h2 {
    font-size: 1.5rem;
    margin-bottom: 1rem;
  }

  .lead-p {
    font-size: 1.05rem;
    line-height: 1.65;
    margin-bottom: 1.75rem;
  }

  .reasons-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .reasons-list li {
    display: flex;
    gap: 0.85rem;
    align-items: flex-start;
  }

  .reason-icon {
    flex-shrink: 0;
    margin-top: 2px;
  }

  .reasons-list strong {
    display: block;
    color: var(--text-main);
    font-size: 1.05rem;
    margin-bottom: 0.2rem;
  }

  .margin-top { margin-top: 1.75rem; }
  .margin-top-sm { margin-top: 0.85rem; }

  .visual-card {
    padding: 0;
    overflow: hidden;
    margin-bottom: 1.5rem;
  }

  .visual-card img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
  }

  .card-caption {
    padding: 1rem 1.25rem;
    background-color: var(--bg-surface);
    border-top: 1px solid var(--border-stone);
  }

  .sidebar-cta-box {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }

  .w-full { width: 100%; }

  @media (max-width: 900px) {
    .service-detail-grid { grid-template-columns: 1fr; }
  }
</style>
