---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import QuickQuoteCTA from '../../components/QuickQuoteCTA.astro';

import { Bath, CheckCircle2, ShieldCheck, Phone, ArrowRight, Clock, Sparkles } from 'lucide-react';

const scope = [
  {
    title: 'Demontaż & Wyburzenia',
    desc: 'Skucie starych płytek, usunięcie starej armatury i wyniesienie gruzu przed przebudową.'
  },
  {
    title: 'Korekty Instalacji Wod-Kan & Elektryki',
    desc: 'Przesunięcie punktów hydraulicznych i elektrycznych pod nowy układ (np. deszczownica podtynkowa, gniazdka przy lustrze).'
  },
  {
    title: 'Odpływ Liniowy & Prysznic Walk-in',
    desc: 'Precyzyjny montaż odpływu liniowego z profilowaniem właściwego spadku 2% w wylewce podłogowej.'
  },
  {
    title: 'Hydroizolacja Powierzchniowa (Strefa Mokra)',
    desc: 'Dwukrotne nakładanie folii w płynie z taśmami w narożnikach — absolutny standard szczelności na lata.'
  },
  {
    title: 'Montaż Płytek i Gierowanie 45°',
    desc: 'Cięcie tarczą diamentową na mokro, szlifowanie zewnętrznych krawędzi bez plastikowych profili.'
  },
  {
    title: 'Biały Montaż & Silikonowanie',
    desc: 'Podłączenie ceramiki, armatury, kabiny ze szkła hartowanego i elastyczne fugowanie silikonami.'
  }
];
---

<Layout 
  title="Remont Łazienki Pod Klucz | TSS Płytki Kraków"
  description="Kompleksowy remont łazienki — skucie, hydroizolacja, płytki, biały montaż. Jedna ekipa, jeden termin. Kraków, Węglówka, Myślenice."
>
  <Navbar slot="navbar" />

  <section class="page-hero section-padding">
    <div class="container-custom">
      <div class="hero-badge">
        <Bath size={16} class="text-gold" />
        <span>Kompleksowy Remont</span>
      </div>
      <h1>Remonty łazienek pod klucz</h1>
      <p class="page-intro">
        Remont łazienki to nie tylko nowe płytki — to demontaż, instalacje, uszczelnienie i montaż armatury w jednym ciągu prac. Robimy to jako jedna ekipa z jednym harmonogramem.
      </p>
    </div>
  </section>

  <section class="section-padding bg-surface-wrap">
    <div class="container-custom">
      <div class="service-detail-grid">

        <div class="detail-main">
          <div class="glass-card detail-card">
            <h2>Kompleksowy zakres prac krok po kroku</h2>
            <p className="lead-p">
              Nie musisz szukać hydraulika, glazurnika i elektryka osobno. Zespół TSS Płytki pod kierownictwem Władysława Kuchni realizuje cały projekt od skucia po wieszenie lustra.
            </p>

            <div class="scope-grid">
              {scope.map((item, idx) => (
                <div class="scope-card">
                  <div class="scope-header">
                    <span class="scope-num">0{idx + 1}</span>
                    <strong>{item.title}</strong>
                  </div>
                  <p>{item.desc}</p>
                </div>
              ))}
            </div>
          </div>

          <div class="glass-card detail-card margin-top">
            <h3>Dlaczego hydroizolacja jest u nas nie do pominięcia?</h3>
            <p>
              Wilgoć, która przenika przez nieuszczelnioną fugę, niszczy wylewkę i ściany sąsiednie zanim będzie to widać na powierzchni. Traktujemy folie w płynie i taśmy uszczelniające jako standardowy etap remontu, nie opcję do dopłaty.
            </p>
          </div>
        </div>

        <div class="detail-sidebar">
          <div class="glass-card visual-card">
            <img src="/images/after.jpeg" alt="Gotowa łazienka z walk-in po remoncie pod klucz w Krakowie" />
            <div class="card-caption">
              <strong>Efekt Po Remoncie</strong>
              <small>Łazienka z prysznicem walk-in, mozaiką i gierowanym narożnikiem</small>
            </div>
          </div>

          <div class="glass-card sidebar-cta-box">
            <ShieldCheck size={28} class="text-emerald" />
            <h4>100% Gwarancja Szczelności</h4>
            <p>Stosujemy sprawdzoną technologię hydroizolacji podpłytkowej w każdej realizowanej łazience.</p>
            <a href="tel:603100978" class="btn btn-primary btn-sm w-full">
              <Phone size={16} />
              <span>Zadzwoń: 603 100 978</span>
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <QuickQuoteCTA 
    title="Chcesz poznać cenę i termin remontu swojej łazienki?" 
    subtitle="Zadzwoń lub opisz projekt w naszym formularzu wyceny on-line — przyjedziemy na darmowy pomiar."
  />

  <Footer slot="footer" />
</Layout>

<style>
  .page-hero {
    padding-top: 4rem;
    padding-bottom: 3rem;
    text-align: center;
    background: radial-gradient(circle at 50% 20%, rgba(212, 163, 115, 0.08) 0%, transparent 60%);
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.35rem 0.85rem;
    background-color: var(--bg-card);
    border: 1px solid var(--border-gold);
    border-radius: var(--radius-full);
    font-size: 0.825rem;
    font-weight: 700;
    color: var(--accent-travertine);
    margin-bottom: 1rem;
  }

  .page-intro {
    font-size: 1.15rem;
    line-height: 1.65;
    max-width: 780px;
    margin: 1rem auto 0 auto;
    color: var(--text-muted);
  }

  .bg-surface-wrap {
    background-color: #0B0E14;
    border-top: 1px solid var(--border-stone);
    border-bottom: 1px solid var(--border-stone);
  }

  .service-detail-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 2.5rem;
  }

  .detail-card {
    padding: 2.25rem;
  }

  .lead-p {
    font-size: 1.05rem;
    line-height: 1.65;
    margin-bottom: 1.75rem;
  }

  .scope-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1.25rem;
  }

  .scope-card {
    padding: 1.25rem;
    background-color: var(--bg-surface);
    border: 1px solid var(--border-stone);
    border-radius: var(--radius-md);
  }

  .scope-header {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    margin-bottom: 0.5rem;
  }

  .scope-num {
    font-family: var(--font-heading);
    font-weight: 800;
    color: var(--accent-travertine);
    font-size: 1.1rem;
  }

  .scope-card strong {
    color: var(--text-main);
    font-size: 0.95rem;
  }

  .scope-card p {
    font-size: 0.875rem;
    line-height: 1.5;
  }

  .margin-top { margin-top: 1.75rem; }

  .visual-card {
    padding: 0;
    overflow: hidden;
    margin-bottom: 1.5rem;
  }

  .visual-card img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
  }

  .card-caption {
    padding: 1rem 1.25rem;
    background-color: var(--bg-surface);
    border-top: 1px solid var(--border-stone);
  }

  .sidebar-cta-box {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    align-items: flex-start;
  }

  .w-full { width: 100%; }

  @media (max-width: 900px) {
    .service-detail-grid { grid-template-columns: 1fr; }
  }
</style>
