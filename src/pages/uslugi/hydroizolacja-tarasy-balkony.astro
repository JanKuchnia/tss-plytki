---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import QuickQuoteCTA from '../../components/QuickQuoteCTA.astro';

import { Sun, CheckCircle2, ShieldCheck, Phone, Droplets } from 'lucide-react';

const scope = [
  {
    title: 'Membrany & Folie w Płynie',
    desc: 'Dwukrotna aplikacja powłok uszczelniających tworzących bezszwową warstwę pod płytkami odporną na podciąganie wilgoci.'
  },
  {
    title: 'Taśmy Dylatacyjne i Narożne',
    desc: 'Wklejanie elastycznych taśm uszczelniających w stykach ściana-podłoga oraz na dylatacjach budowlanych.'
  },
  {
    title: 'Profile Okapowe i Odwodnienie',
    desc: 'Montaż aluminiowych okapników odprowadzających wód opadową poza czoło balkonu, zapobiegając zaciekom na elewacji.'
  },
  {
    title: 'Płytki Gresowe Mrozoodporne',
    desc: 'Układanie gresu o niskiej nasiąkliwości wodnej (klasa AIa / BIa) ze spoiną elastyczną dostosowaną do zmian temperatur.'
  }
];
---

<Layout 
  title="Hydroizolacja Tarasu i Balkonu | Płytki Mrozoodporne — TSS Płytki"
  description="Izolacja podpłytkowa, taśmy uszczelniające i mrozoodporny gres na tarasy i balkony — przygotowane na polską zimę. Kraków, Małopolska."
>
  <Navbar slot="navbar" />

  <section class="page-hero section-padding">
    <div class="container-custom">
      <div class="hero-badge">
        <Sun size={16} class="text-gold" />
        <span>Ochrona Zewnętrzna & Wet-Zone</span>
      </div>
      <h1>Hydroizolacja i tarasy/balkony</h1>
      <p class="page-intro">
        Taras czy balkon bez prawidłowej hydroizolacji wygląda dobrze przez jeden sezon — a potem woda znajduje drogę pod płytki, zamarza zimą i rozsadza je od spodu.
      </p>
    </div>
  </section>

  <section class="section-padding bg-surface-wrap">
    <div class="container-custom">
      <div class="service-detail-grid">

        <div class="detail-main">
          <div class="glass-card detail-card">
            <h2>Systemy izolacyjne odporne na polską zimę</h2>
            <p className="lead-p">
              Wykonujemy pełną izolację podpłytkową na tarasach, balkonach oraz w strefach mokrych (walk-in). Dajemy 100% gwarancji szczelności.
            </p>

            <div class="scope-grid">
              {scope.map(s => (
                <div class="scope-card">
                  <CheckCircle2 size={20} class="text-gold scope-icon" />
                  <div>
                    <strong>{s.title}</strong>
                    <p>{s.desc}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>

          <div class="glass-card detail-card margin-top">
            <h3>Dlaczego profilowanie spadku jest kluczowe?</h3>
            <p>
              Spadek 1.5%–2% wylewki w kierunku okapnika sprawia, że woda spływa naturalnie i nie zalega na powierzchni. Prawidłowy spadek w połączeniu z taśmami uszczelniającymi to jedyny sposób na trwały taras na dekady.
            </p>
          </div>
        </div>

        <div class="detail-sidebar">
          <div class="glass-card visual-card">
            <img src="/images/gallery-9.jpeg" alt="Taras zewnętrzny z gresu mrozoodpornego" />
            <div class="card-caption">
              <strong>Taras w Węglówce</strong>
              <small>Montaż mrozoodpornych płyt gresowych z izolacją podpłytkową</small>
            </div>
          </div>

          <div class="glass-card sidebar-cta-box">
            <ShieldCheck size={28} class="text-emerald" />
            <h4>Gwarancja Szczelności</h4>
            <p>Usługa wykonana raz porządnie chroni konstrukcję budowlaną przez wiele lat.</p>
            <a href="tel:603100978" class="btn btn-primary btn-sm w-full">
              <Phone size={16} />
              <span>Zadzwoń: 603 100 978</span>
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <QuickQuoteCTA 
    title="Planujesz remont tarasu lub balkonu na wiosnę?" 
    subtitle="Zadzwoń do nas: 603 100 978 — zarezerwuj termin w dogodnym czasie."
  />

  <Footer slot="footer" />
</Layout>

<style>
  .page-hero {
    padding-top: 4rem;
    padding-bottom: 3rem;
    text-align: center;
    background: radial-gradient(circle at 50% 20%, rgba(212, 163, 115, 0.08) 0%, transparent 60%);
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.35rem 0.85rem;
    background-color: var(--bg-card);
    border: 1px solid var(--border-gold);
    border-radius: var(--radius-full);
    font-size: 0.825rem;
    font-weight: 700;
    color: var(--accent-travertine);
    margin-bottom: 1rem;
  }

  .page-intro {
    font-size: 1.15rem;
    line-height: 1.65;
    max-width: 780px;
    margin: 1rem auto 0 auto;
    color: var(--text-muted);
  }

  .bg-surface-wrap {
    background-color: #0B0E14;
    border-top: 1px solid var(--border-stone);
    border-bottom: 1px solid var(--border-stone);
  }

  .service-detail-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 2.5rem;
  }

  .detail-card {
    padding: 2.25rem;
  }

  .lead-p {
    font-size: 1.05rem;
    line-height: 1.65;
    margin-bottom: 1.75rem;
  }

  .scope-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1.25rem;
  }

  .scope-card {
    display: flex;
    gap: 0.75rem;
    padding: 1.1rem;
    background-color: var(--bg-surface);
    border: 1px solid var(--border-stone);
    border-radius: var(--radius-md);
  }

  .scope-icon {
    flex-shrink: 0;
    margin-top: 2px;
  }

  .scope-card strong {
    display: block;
    color: var(--text-main);
    font-size: 0.95rem;
    margin-bottom: 0.2rem;
  }

  .scope-card p {
    font-size: 0.85rem;
    line-height: 1.5;
  }

  .margin-top { margin-top: 1.75rem; }

  .visual-card {
    padding: 0;
    overflow: hidden;
    margin-bottom: 1.5rem;
  }

  .visual-card img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
  }

  .card-caption {
    padding: 1rem 1.25rem;
    background-color: var(--bg-surface);
    border-top: 1px solid var(--border-stone);
  }

  .sidebar-cta-box {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }

  .w-full { width: 100%; }

  @media (max-width: 900px) {
    .service-detail-grid { grid-template-columns: 1fr; }
  }
</style>
