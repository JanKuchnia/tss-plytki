---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import TileCalculator from '../components/TileCalculator.jsx';
import QuickQuoteCTA from '../components/QuickQuoteCTA.astro';

import { Calculator, Sparkles } from 'lucide-react';
---

<Layout 
  title="Kalkulator Płytek — Ile Materiału Potrzebujesz? | TSS Płytki"
  description="Oblicz zapotrzebowanie na płytki, zapas na docinki i orientacyjny koszt materiału. Darmowy kalkulator TSS Płytki dla Krakowa i Małopolsce."
>
  <Navbar slot="navbar" />

  <section class="page-hero section-padding">
    <div class="container-custom">
      <div class="hero-badge">
        <Calculator size={16} class="text-gold" />
        <span>Narzędzie Do Planowania Budżetu</span>
      </div>
      <h1>Kalkulator zapotrzebowania na płytki</h1>
      <p class="page-intro">
        Podaj metraż pomieszczenia, wybierz format płytek i wzór układania — kalkulator policzy potrzebną powierzchnię, liczbę kartonów z zapasem na docinki oraz orientacyjne widełki kosztów materiału.
      </p>
    </div>
  </section>

  <section class="section-padding bg-surface-wrap">
    <div class="container-custom">
      <TileCalculator client:load />

      <div class="disclaimer-box glass-card text-center">
        <Sparkles size={20} class="text-gold" />
        <p>
          To orientacyjne wyliczenie materiału do wstępnego planowania budżetu — dokładną wycenę materiału i robocizny (razem z realnym terminem realizacji) dostaniesz po darmowych oględzinach na miejscu w Krakowie lub okolicach.
        </p>
      </div>
    </div>
  </section>

  <QuickQuoteCTA 
    title="Chcesz dokładną wycenę na podstawie tego wyliczenia?" 
    subtitle="Zadzwoń do nas: 603 100 978 — omówimy szczegoły i przyjedziemy na darmowy pomiar."
  />

  <Footer slot="footer" />
</Layout>

<style>
  .page-hero {
    padding-top: 4rem;
    padding-bottom: 3rem;
    text-align: center;
    background: radial-gradient(circle at 50% 20%, rgba(212, 163, 115, 0.08) 0%, transparent 60%);
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.35rem 0.85rem;
    background-color: var(--bg-card);
    border: 1px solid var(--border-gold);
    border-radius: var(--radius-full);
    font-size: 0.825rem;
    font-weight: 700;
    color: var(--accent-travertine);
    margin-bottom: 1rem;
  }

  .page-intro {
    font-size: 1.15rem;
    line-height: 1.65;
    max-width: 780px;
    margin: 1rem auto 0 auto;
    color: var(--text-muted);
  }

  .bg-surface-wrap {
    background-color: #0B0E14;
    border-top: 1px solid var(--border-stone);
    border-bottom: 1px solid var(--border-stone);
  }

  .disclaimer-box {
    max-width: 820px;
    margin: 3rem auto 0 auto;
    padding: 1.5rem 2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    font-size: 0.925rem;
    color: var(--text-muted);
  }

  .text-center { text-align: center; }
</style>
