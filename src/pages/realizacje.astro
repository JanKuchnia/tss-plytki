---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Gallery from '../components/Gallery.jsx';
import QuickQuoteCTA from '../components/QuickQuoteCTA.astro';

import { Images, Sparkles, Phone, ArrowRight } from 'lucide-react';
---

<Layout 
  title="Realizacje | TSS Płytki — Łazienki, Kuchnie, Tarasy, Wielki Format"
  description="Zobacz zrealizowane projekty TSS Płytki — remonty łazienek, podłogi wielkoformatowe, tarasy i kuchnie w Krakowie i Małopolsce."
>
  <Navbar slot="navbar" />

  <section class="page-hero section-padding">
    <div class="container-custom">
      <div class="hero-badge">
        <Images size={16} class="text-gold" />
        <span>Portfolio Realizacji</span>
      </div>
      <h1>Nasze zrealizowane projekty</h1>
      <p class="page-intro">
        Każde zdjęcie to dokończony projekt — nie wizualizacja komputerowa. Filtruj według kategorii i kliknij w dowolne zdjęcie, by zobaczyć je w pełnym rozmiarze ze szczegółami docięć i gierowania.
      </p>
    </div>
  </section>

  <section class="section-padding bg-surface-wrap">
    <div class="container-custom">
      <Gallery client:load />
    </div>
  </section>

  <QuickQuoteCTA 
    title="Podoba Ci się któryś z naszych projektów?"
    subtitle="Opisz, co chcesz zrealizować w swoim domu — zadzwoń: 603 100 978 lub wypełnij bezpłatny formularz wyceny."
  />

  <Footer slot="footer" />
</Layout>

<style>
  .page-hero {
    padding-top: 4rem;
    padding-bottom: 3rem;
    text-align: center;
    background: radial-gradient(circle at 50% 20%, rgba(212, 163, 115, 0.08) 0%, transparent 60%);
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.35rem 0.85rem;
    background-color: var(--bg-card);
    border: 1px solid var(--border-gold);
    border-radius: var(--radius-full);
    font-size: 0.825rem;
    font-weight: 700;
    color: var(--accent-travertine);
    margin-bottom: 1rem;
  }

  .page-intro {
    font-size: 1.15rem;
    line-height: 1.65;
    max-width: 780px;
    margin: 1rem auto 0 auto;
    color: var(--text-muted);
  }

  .bg-surface-wrap {
    background-color: #0B0E14;
    border-top: 1px solid var(--border-stone);
    border-bottom: 1px solid var(--border-stone);
  }
</style>
