---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import ProjectWizard from '../components/ProjectWizard.jsx';

import { Phone, Mail, MapPin, Clock, Facebook, FileText, CheckCircle2, MessageSquare } from 'lucide-react';
---

<Layout 
  title="Kontakt | TSS Płytki — Kraków, Węglówka, Myślenice"
  description="Skontaktuj się z TSS Płytki — bezpłatna wycena remontu łazienki, układania płytek lub hydroizolacji w Krakowie i Małopolsce. Telefon: 603 100 978."
>
  <Navbar slot="navbar" />

  <section class="page-hero section-padding">
    <div class="container-custom">
      <div class="hero-badge">
        <MessageSquare size={16} class="text-gold" />
        <span>Darmowa Wycena & Pomiar</span>
      </div>
      <h1>Porozmawiajmy o Twoim projekcie</h1>
      <p class="page-intro">
        Najszybciej zadzwoń — odpowiemy na pytania i umówimy terminy oględzin. Możesz też wysłać formularz ze zdjęciami obecnego stanu pomieszczenia.
      </p>
    </div>
  </section>

  <section class="section-padding bg-surface-wrap">
    <div class="container-custom">
      <div class="contact-page-grid">

        <!-- Left: Contact Details Card -->
        <div class="contact-info-col">
          <div class="glass-card contact-card">
            <h3>Dane Kontaktowe</h3>
            <p className="card-subtext">Bezpośredni kontakt do właściciela firmy (Władysław Kuchnia):</p>

            <ul class="contact-list">
              <li>
                <div class="icon-box">
                  <Phone size={20} class="text-gold" />
                </div>
                <div>
                  <strong>Telefon bezpośredni:</strong>
                  <a href="tel:603100978" class="contact-link">603 100 978</a>
                </div>
              </li>

              <li>
                <div class="icon-box">
                  <Mail size={20} class="text-gold" />
                </div>
                <div>
                  <strong>Adres e-mail:</strong>
                  <a href="mailto:tssplytki@gmail.com" class="contact-link">tssplytki@gmail.com</a>
                </div>
              </li>

              <li>
                <div class="icon-box">
                  <MapPin size={20} class="text-gold" />
                </div>
                <div>
                  <strong>Siedziba firmy:</strong>
                  <span>Węglówka 104, 32-412 Węglówka</span>
                  <small className="d-block text-muted">Większość prac realizujemy w Krakowie i okolicach</small>
                </div>
              </li>

              <li>
                <div class="icon-box">
                  <Clock size={20} class="text-gold" />
                </div>
                <div>
                  <strong>Godziny otwarcia:</strong>
                  <span>Poniedziałek – Piątek: 07:00 – 17:00</span>
                  <small className="d-block text-dim">Sobota – Niedziela: zamknięte</small>
                </div>
              </li>

              <li>
                <div class="icon-box">
                  <FileText size={20} class="text-gold" />
                </div>
                <div>
                  <strong>Dane rejestrowe:</strong>
                  <span>NIP: 681-135-28-13</span>
                </div>
              </li>

              <li>
                <div class="icon-box">
                  <Facebook size={20} class="text-gold" />
                </div>
                <div>
                  <strong>Facebook:</strong>
                  <a href="https://www.facebook.com/tssplytki/" target="_blank" rel="noopener noreferrer" class="contact-link">
                    facebook.com/tssplytki/
                  </a>
                </div>
              </li>
            </ul>

            <div class="call-now-box">
              <a href="tel:603100978" class="btn btn-primary btn-lg w-full">
                <Phone size={20} />
                <span>Zadzwoń teraz: 603 100 978</span>
              </a>
            </div>
          </div>

          <!-- Embedded Map -->
          <div class="glass-card map-card">
            <h4>Siedziba firmy — Węglówka (Małopolska)</h4>
            <div class="map-container">
              <iframe 
                src="https://maps.google.com/maps?q=W%C4%99gl%C3%B3wka%20104,%2032-412%20W%C4%99gl%C3%B3wka&t=&z=13&ie=UTF8&iwloc=&output=embed" 
                width="100%" 
                height="280" 
                style="border:0;" 
                allowfullscreen="" 
                loading="lazy"
                title="Lokalizacja TSS Płytki — Węglówka 104"
              ></iframe>
            </div>
          </div>
        </div>

        <!-- Right: Interactive Inquiry Form -->
        <div class="contact-form-col">
          <ProjectWizard client:load />
        </div>

      </div>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>

<style>
  .page-hero {
    padding-top: 4rem;
    padding-bottom: 3rem;
    text-align: center;
    background: radial-gradient(circle at 50% 20%, rgba(212, 163, 115, 0.08) 0%, transparent 60%);
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.35rem 0.85rem;
    background-color: var(--bg-card);
    border: 1px solid var(--border-gold);
    border-radius: var(--radius-full);
    font-size: 0.825rem;
    font-weight: 700;
    color: var(--accent-travertine);
    margin-bottom: 1rem;
  }

  .page-intro {
    font-size: 1.15rem;
    line-height: 1.65;
    max-width: 780px;
    margin: 1rem auto 0 auto;
    color: var(--text-muted);
  }

  .bg-surface-wrap {
    background-color: #0B0E14;
    border-top: 1px solid var(--border-stone);
    border-bottom: 1px solid var(--border-stone);
  }

  .contact-page-grid {
    display: grid;
    grid-template-columns: 1fr 1.15fr;
    gap: 2.5rem;
    align-items: flex-start;
  }

  .contact-info-col {
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
  }

  .contact-card {
    padding: 2.25rem;
  }

  .contact-card h3 {
    font-size: 1.35rem;
    margin-bottom: 0.35rem;
  }

  .card-subtext {
    font-size: 0.9rem;
    margin-bottom: 1.5rem;
  }

  .contact-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    margin-bottom: 2rem;
  }

  .contact-list li {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }

  .icon-box {
    width: 40px;
    height: 40px;
    border-radius: var(--radius-md);
    background-color: var(--bg-surface);
    border: 1px solid var(--border-stone);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .contact-list strong {
    display: block;
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-bottom: 0.15rem;
  }

  .contact-list span {
    font-size: 0.95rem;
    color: var(--text-main);
    font-weight: 600;
  }

  .contact-link {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--accent-travertine);
  }

  .contact-link:hover {
    text-decoration: underline;
  }

  .d-block { display: block; }

  .call-now-box {
    margin-top: 1rem;
  }

  .w-full { width: 100%; }

  .map-card {
    padding: 1.5rem;
  }

  .map-card h4 {
    font-size: 1.05rem;
    margin-bottom: 1rem;
  }

  .map-container {
    border-radius: var(--radius-md);
    overflow: hidden;
    border: 1px solid var(--border-stone);
  }

  @media (max-width: 900px) {
    .contact-page-grid { grid-template-columns: 1fr; }
  }

  @media (max-width: 640px) {
    .contact-card {
      padding: 1.5rem 1.15rem;
    }
    .contact-list li {
      word-break: break-word;
      overflow-wrap: anywhere;
    }
    .contact-link {
      word-break: break-all;
      overflow-wrap: anywhere;
    }
    .map-card {
      padding: 1.25rem 1rem;
    }
  }
</style>
