---
import { HelpCircle, ChevronDown, Phone } from 'lucide-react';

const faqs = [
  {
    q: 'Ile trwa remont łazienki albo układanie płytek?',
    a: 'To zależy od zakresu prac i metrażu, ale dzięki 25 latom wprawy realizujemy je sprawnie, bez zbędnych przestojów — bez skracania samego procesu technologii schnięcia. Dokładny termin i czas realizacji ustalamy po oględzinach — zadzwoń w godzinach pracy (pon–pt 7:00–17:00).'
  },
  {
    q: 'Czy hydroizolacja jest wliczona w remont łazienki?',
    a: 'Tak, przy remontach pod klucz hydroizolacja podpłytkowa (folia w płynie, taśmy uszczelniające strefę mokrą) jest standardowym etapem, nie płatnym dodatkiem — to ona decyduje, czy łazienka będzie szczelna za 10 lat, nie tylko ładna dziś.'
  },
  {
    q: 'Czym różni się gierowanie 45° od zwykłego narożnika?',
    a: 'Przy gierowaniu krawędź płytki jest docinana tarczą diamentową pod kątem 45° i łączona bezpośrednio z sąsiednią płytką — bez plastikowego ani metalowego profilu w rogu. Efekt jest czystszy wizualnie i trwalszy, bo nie ma elementu, który z czasem żółknie lub odpada.'
  },
  {
    q: 'Czy pomagacie w doborze i zakupie płytek?',
    a: 'Tak, doradzamy przy wyborze formatu i rodzaju płytek pod kątem specyfiki pomieszczenia (np. gres mrozoodporny na taras, płyty wielkoformatowe do salonu) — możesz kupić płytki samodzielnie lub skorzystać z naszych sprawdzonych rekomendacji.'
  },
  {
    q: 'Czy działacie poza Węglówką?',
    a: 'Tak — najwięcej realizacji wykonujemy w Krakowie, a poza tym regularnie pracujemy w Wiśniowej, Myślenicach, Dobczycach, Rabce-Zdroju, Mszanie Dolnej i Limanowej. Zadzwoń: 603 100 978, jeśli Twoja miejscowość leży w okolicy.'
  }
];

const faqPageSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(item => ({
    "@type": "Question",
    "name": item.q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.a
    }
  }))
};
---

<section class="faq-section section-padding">
  <script type="application/ld+json" set:html={JSON.stringify(faqPageSchema)} />

  <div class="container-custom">
    <div class="section-header">
      <span class="badge badge-gold">FAQ</span>
      <h2>Najczęściej zadawane pytania</h2>
      <p>Odpowiedzi na kluczowe pytania przed rozpoczęciem prac glazurniczych i remontowych.</p>
    </div>

    <div class="faq-accordion-wrapper">
      {faqs.map((faq, index) => (
        <details class="faq-item glass-card" open={index === 0}>
          <summary class="faq-question">
            <span>{faq.q}</span>
            <ChevronDown size={18} class="chevron-icon text-gold" />
          </summary>
          <div class="faq-answer">
            <p>{faq.a}</p>
          </div>
        </details>
      ))}
    </div>

    <div class="faq-footer-contact">
      <p>Masz inne pytanie dotyczące Twojego remontu?</p>
      <a href="tel:603100978" class="btn btn-secondary btn-sm">
        <Phone size={16} />
        <span>Zadzwoń do Władysława: 603 100 978</span>
      </a>
    </div>
  </div>
</section>

<style>
  .faq-accordion-wrapper {
    max-width: 820px;
    margin: 0 auto 2.5rem auto;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .faq-item {
    padding: 0;
    overflow: hidden;

  }

  .faq-question {
    padding: 1.35rem 1.5rem;
    font-family: var(--font-heading);
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--text-main);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    list-style: none;
    user-select: none;
  }

  .faq-question::-webkit-details-marker {
    display: none;
  }

  .chevron-icon {
    transition: transform var(--transition-normal);
    flex-shrink: 0;
  }

  details[open] .chevron-icon {
    transform: rotate(180deg);
  }

  .faq-answer {
    padding: 0 1.5rem 1.5rem 1.5rem;
    border-top: 1px solid var(--border-stone);
    margin-top: 0.5rem;
    padding-top: 1rem;
  }

  .faq-answer p {
    font-size: 0.95rem;
    line-height: 1.65;
    color: var(--text-muted);
  }

  .faq-footer-contact {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }

  .faq-footer-contact p {
    font-size: 0.95rem;
  }
</style>
