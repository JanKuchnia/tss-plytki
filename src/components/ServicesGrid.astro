---
import { Layers, Bath, Grid, Home, Sun, Wrench, ArrowRight } from 'lucide-react';

const services = [
  {
    icon: Grid,
    title: 'Układanie Płytek Wielkoformatowych',
    desc: 'Płyty 120×120 i 120×240 cm, montaż próżniowy, idealnie wąska spoina i poziomowanie płaszczyzn.',
    href: '/uslugi/ukladanie-plytek-wielkoformatowych',
    tag: 'Wielki Format'
  },
  {
    icon: Bath,
    title: 'Remonty Łazienek Pod Klucz',
    desc: 'Od skucia starych płytek po biały montaż — jedna ekipa, jeden termin i 100% gwarancja szczelności.',
    href: '/uslugi/remonty-lazienek-pod-klucz',
    tag: 'Pod Klucz'
  },
  {
    icon: Wrench,
    title: 'Cięcie Precyzyjne i Gierowanie 45°',
    desc: 'Czyste narożniki bez szpecących plastikowych i metalowych listw. Kamień styka się z kamieniem.',
    href: '/uslugi/ciecie-45-gierowanie',
    tag: 'Precyzja'
  },
  {
    icon: Home,
    title: 'Wykończenia Wnętrz i Posadzki',
    desc: 'Salony, kuchnie, fartuchy kuchenne, kominki, schody z fugowaniem epoksydowym i cementowym.',
    href: '/uslugi/wykonczenia-wnetrz-posadzki',
    tag: 'Wnętrza'
  },
  {
    icon: Sun,
    title: 'Hydroizolacja i Tarasy / Balkony',
    desc: 'Izolacja podpłytkowa, folie w płynie, taśmy uszczelniające i mrozoodporny gres na zewnątrz.',
    href: '/uslugi/hydroizolacja-tarasy-balkony',
    tag: 'Zewnętrzne'
  },
  {
    icon: Layers,
    title: 'Wylewki i Przygotowanie Podłoża',
    desc: 'Wylewki samopoziomujące, szlifowanie podłoża i kontrola poziomu laserem przed ułożeniem płytek.',
    href: '/uslugi/wylewki-samopoziomujace',
    tag: 'Podłoże'
  }
];
---

<section class="services-grid-section section-padding">
  <div class="container-custom">
    <div class="section-header">
      <span class="badge badge-gold">Czym się zajmujemy</span>
      <h2>Sześć specjalizacji, jeden zespół</h2>
      <p>Od przygotowania podłoża i hydroizolacji po Ostatnią fugę — rzemiosło bez kompromisów.</p>
    </div>

    <div class="services-grid">
      {services.map((service) => {
        const Icon = service.icon;
        return (
          <div class="service-card glass-card">
            <div class="card-header-row">
              <div class="service-icon-box">
                <Icon size={24} class="text-gold" />
              </div>
              <span class="service-tag">{service.tag}</span>
            </div>

            <h3>{service.title}</h3>
            <p>{service.desc}</p>

            <a href={service.href} class="btn-link">
              <span>Zobacz szczegóły</span>
              <ArrowRight size={16} class="link-arrow" />
            </a>
          </div>
        );
      })}
    </div>
  </div>
</section>

<style>
  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.75rem;
  }

  .service-card {
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .card-header-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .service-icon-box {
    width: 48px;
    height: 48px;
    border-radius: var(--radius-md);
    background-color: var(--bg-surface);
    border: 1px solid var(--border-gold);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .service-tag {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.25rem 0.65rem;
    background-color: var(--bg-surface);
    border: 1px solid var(--border-stone);
    border-radius: var(--radius-full);
    color: var(--text-muted);
  }

  .service-card h3 {
    font-size: 1.25rem;
    color: var(--text-main);
  }

  .service-card p {
    font-size: 0.925rem;
    line-height: 1.6;
    flex: 1;
  }

  .btn-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 700;
    font-size: 0.9rem;
    color: var(--accent-travertine);
    margin-top: 0.5rem;
  }

  .btn-link:hover .link-arrow {
    transform: translateX(4px);
  }

  .link-arrow {
    transition: transform var(--transition-fast);
  }
</style>
